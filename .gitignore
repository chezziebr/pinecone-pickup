# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# security & credentials
*.key
*.p12
*.pfx
*credentials*.json
*config*.json
secrets.json
.secrets
.credentials
service-account*.json
google-credentials*.json

# database
*.db
*.sqlite
*.sqlite3

# logs
*.log
logs/
.logs/

# IDEs and editors
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# temporary files
.tmp/
temp/
.temp/

# OAuth token artifacts (never commit these)
token.json
tokens.json
*.refresh-token
.oauth-tokens/

# Claude Code harness state
.claude/

# .env*.local — added by `vercel env pull`, kept for tooling compatibility (already covered by .env* above)
.env*.local
